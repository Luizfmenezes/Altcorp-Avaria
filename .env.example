# =============================================================================
# Altcorp Avarias — exemplo de configuracao
# Copie para .env e ajuste antes de subir os containers:
#   cp .env.example .env
# =============================================================================

# IP/host publico do servidor onde o stack roda.
# Para deploy em VM da rede: use o IP da VM (ex: 192.168.1.50).
# Para acesso local: use localhost.
# Esse valor e usado pelo browser do cliente, MinIO public URL e CORS.
HOST_IP=localhost

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=avarias
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_DB=avarias

# -----------------------------------------------------------------------------
# MinIO (storage de fotos)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=CHANGE_ME_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password
MINIO_BUCKET=avarias-photos

# -----------------------------------------------------------------------------
# Backend — gere JWT_SECRET com: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# URL publica do MinIO. Em producao via HTTPS, aponte para o proxy nginx:
#   MINIO_PUBLIC_URL=https://seu-dominio.com/photos
# (nginx /photos/ faz proxy para minio:9000 — sem mixed content)
MINIO_PUBLIC_URL=http://localhost:9000

# Origins permitidas pelo backend. Em producao, inclua o dominio publico do app.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8080

# Frontends em container devem usar o proxy reverso do nginx para falar com a API.
VITE_API_URL=/api

# Conta admin inicial criada na primeira subida (deixe em branco para nao seedar)
SEED_ADMIN_EMAIL=admin@altcorp.com
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_strong_password

# -----------------------------------------------------------------------------
# SPTrans Olho Vivo — rastreamento de onibus em tempo real.
# Token em https://www.sptrans.com.br/desenvolvedores/
# -----------------------------------------------------------------------------
OLHOVIVO_TOKEN=
OLHOVIVO_BASE_URL=http://api.olhovivo.sptrans.com.br/v2.1
